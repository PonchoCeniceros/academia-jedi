      "type": "text",
      "x": 275.55206707314073,
      "y": 30.185127762776915,
      "width": 541.08203125,
      "height": 300,
      "angle": 0,
      "strokeColor": "#099268",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
