      "link": null,
      "locked": false,
      "text": "i=0:\n[]   0:0 → 0:i\n[+]  1:2 → i+1:n\n\ni=1:\n[]   2:2 → i+1:n\n[-]  0:1 → 0:i",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "i=0:\n[]   0:0 → 0:i\n[+]  1:2 → i+1:n\n\ni=1:\n[]   2:2 → i+1:n\n[-]  0:1 → 0:i",
      "autoResize": true,
      "lineHeight": 1.25
    },
