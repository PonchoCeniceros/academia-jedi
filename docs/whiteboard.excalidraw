      "isDeleted": true,
      "boundElements": [],
      "updated": 1782169900585,
      "link": null,
      "locked": false,
      "text": "\nsolver(ε, Ω):\n\n    if ε.len = 1:\n        ret ε\n\n    for i, op in Ω:\n        for x in solve(ε[0, i], Ω[0, i]):\n            for y in solve(ε[i+1, n], Ω[i+1, n]):\n                ans.append(x op y)\n\n    ret ans",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nsolver(ε, Ω):\n\n    if ε.len = 1:\n        ret ε\n\n    for i, op in Ω:\n        for x in solve(ε[0, i], Ω[0, i]):\n            for y in solve(ε[i+1, n], Ω[i+1, n]):\n                ans.append(x op y)\n\n    ret ans",
      "autoResize": true,
      "lineHeight": 1.25
    },
